# --- Database Configuration ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mbm_radar

# --- Redis Configuration ---
REDIS_URL=redis://localhost:6379/0

# --- Telegram Configuration ---
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ
TELEGRAM_CHANNEL_ID=-1001234567890

# --- API Keys for Stock Providers ---
# Primary: FMP (Financial Modeling Prep)
FMP_API_KEY=your_fmp_api_key_here

# Secondary/Optional data providers
POLYGON_API_KEY=your_polygon_api_key_here
FINNHUB_API_KEY=your_finnhub_api_key_here
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_api_secret_here
IEX_CLOUD_API_KEY=your_iex_api_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# --- Active Providers configuration ---
ACTIVE_DATA_PROVIDER=FMP  # Options: FMP, POLYGON, FINNHUB, ALPACA, IEX, ALPHAVANTAGE

# --- JWT & Security Configuration ---
JWT_SECRET=super_secret_jwt_key_change_me_in_production_123456789
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Admin Panel Defaults ---
ADMIN_TELEGRAM_ID=123456789 # Put your telegram chat ID here
ADMIN_PASSWORD=change_this_password_123

# --- Scanner Parameters (Defaults) ---
SCANNER_MAX_PRICE=20.0
SCANNER_MAX_FLOAT=20000000.0
SCANNER_MAX_MARKET_CAP=1500000000.0
SCANNER_MIN_RVOL=3.0
SCANNER_MIN_VOLUME=100000
SCANNER_MIN_GAP_PCT=2.0
SCANNER_MIN_CHANGE_PCT=1.0

# --- Alert System Parameters ---
COOLDOWN_PERIOD_MINUTES=15
MIN_SCORE_THRESHOLD=5.0
